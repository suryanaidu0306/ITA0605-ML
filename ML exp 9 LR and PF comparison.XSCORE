{"nbformat":4,"nbformat_minor":0,"metadata":{"colab":{"provenance":[],"authorship_tag":"ABX9TyN9KILXdmIxl/UnGBnOfLhK"},"kernelspec":{"name":"python3","display_name":"Python 3"},"language_info":{"name":"python"}},"cells":[{"cell_type":"code","execution_count":1,"metadata":{"colab":{"base_uri":"https://localhost:8080/"},"id":"A86RQL8zpSby","executionInfo":{"status":"ok","timestamp":1781600357144,"user_tz":-330,"elapsed":2148,"user":{"displayName":"JANANI SK","userId":"08017685831414027161"}},"outputId":"b8a2e4dc-ff4b-4537-aaac-b4c5b5479593"},"outputs":[{"output_type":"stream","name":"stdout","text":["Linear Regression Prediction: 28.999999999999996\n","Polynomial Regression Prediction: 36.00000000000002\n"]}],"source":["import numpy as np\n","from sklearn.linear_model import LinearRegression\n","from sklearn.preprocessing import PolynomialFeatures\n","\n","# Sample dataset\n","X = np.array([1, 2, 3, 4, 5]).reshape(-1, 1)\n","y = np.array([1, 4, 9, 16, 25])\n","\n","# Linear Regression\n","linear_model = LinearRegression()\n","linear_model.fit(X, y)\n","\n","linear_pred = linear_model.predict([[6]])\n","print(\"Linear Regression Prediction:\", linear_pred[0])\n","\n","# Polynomial Regression (Degree = 2)\n","poly = PolynomialFeatures(degree=2)\n","X_poly = poly.fit_transform(X)\n","\n","poly_model = LinearRegression()\n","poly_model.fit(X_poly, y)\n","\n","poly_pred = poly_model.predict(poly.transform([[6]]))\n","print(\"Polynomial Regression Prediction:\", poly_pred[0])"]}]}